{
  "buildCommand": "npm run build:ssr",
  "outputDirectory": "dist/client",
  "framework": "vite",
  "functions": {
  "api/*.mjs": {
    "maxDuration": 30
  }
},
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*)\\.(svg|png|jpg|jpeg|webp|avif|ico|xml|txt|json)", "destination": "/$1.$2" },
    { "source": "/(favicon\\.svg|robots\\.txt|sitemap\\.xml|BingSiteAuth\\.xml|googlee6b9c8c7a1d2f4b8\\.html)", "destination": "/$1" },
    { "source": "/api/chat", "destination": "/api/chat.mjs" },
    { "source": "/api/embeddings", "destination": "/api/embeddings.mjs" },
    { "source": "/(.*)", "destination": "/api/ssr" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(svg|png|jpg|jpeg|webp|avif|ico|xml|txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
